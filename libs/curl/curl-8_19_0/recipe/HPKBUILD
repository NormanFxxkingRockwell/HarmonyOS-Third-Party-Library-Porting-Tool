pkgname=curl_8_19_0
pkgver=curl-8_19_0
pkgrel=0
pkgdesc="A command line tool and library for transferring data with URL syntax, supporting DICT, FILE, FTP, FTPS, GOPHER, GOPHERS, HTTP, HTTPS, IMAP, IMAPS, LDAP, LDAPS, MQTT, POP3, POP3S, RTMP, RTMPS, RTSP, SCP, SFTP, SMB, SMBS, SMTP, SMTPS, TELNET, TFTP, WS and WSS. libcurl offers a myriad of powerful features"
url="https://curl.se/"
archs=("arm64-v8a")
license=("curl")
depends=("openssl" "zstd" "nghttp2")
makedepends=()

source="https://github.com/curl/curl/archive/refs/tags/curl-8_19_0.zip"

autounpack=true
downloadpackage=true
patchflag=false

builddir=curl-curl-8_19_0
packagename=curl-8_19_0.zip

prepare() {
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DCURL_CA_BUNDLE="/etc/ssl/certs/cacert.pem" \
        -DCURL_CA_PATH="/etc/ssl/certs/" \
        -DCURL_ZSTD=ON \
        -DCURL_USE_PKGCONFIG=OFF \
        -DCURL_USE_LIBPSL=OFF \
        -DENABLE_WEBSOCKETS=ON \
        -DUSE_NGHTTP2=ON \
        -DUSE_LIBIDN2=OFF \
        -DBUILD_TESTING=OFF \
        -DENABLE_CURL_MANUAL=OFF \
        -DPICKY_COMPILER=OFF \
        -B$ARCH-build -S./ > $buildlog 2>&1
    $MAKE -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd "$builddir"
    ${MAKE} -C $ARCH-build install >> `pwd`/$ARCH-build/build.log 2>&1
    ret=$?
    cd $OLDPWD
    return ${ret}
}

check() {
    cd "$builddir"
    echo "Test via curl CLI on device"
    cd $OLDPWD
}

cleanbuild() {
    rm -rf ${PWD}/$builddir
}