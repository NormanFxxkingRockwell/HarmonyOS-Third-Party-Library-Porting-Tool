+import { hilog } from '@kit.PerformanceAnalysisKit';
+import testNapi from 'libentry.so';
+
+const DOMAIN = 0x0000;
+
+@Entry
+@Component
+struct Index {
+  @State message: string = 'Preparing cJSON smoke test...';
+
+  private runSmoke(): void {
+    try {
+      const result = testNapi.runCjsonSmoke();
+      this.message = result;
+      hilog.info(DOMAIN, 'cJSONTest', 'cJSON smoke result: %{public}s', result);
+    } catch (err) {
+      const errorText = `pass=false;reason=${JSON.stringify(err)}`;
+      this.message = errorText;
+      hilog.error(DOMAIN, 'cJSONTest', 'cJSON smoke failed: %{public}s', errorText);
+    }
+  }
+
+  aboutToAppear(): void {
+    this.runSmoke();
+  }
+
+  build() {
+    Scroll() {
+      Column({ space: 16 }) {
+        Text('cJSON HAP Smoke Test')
+          .fontSize(24)
+          .fontWeight(FontWeight.Bold)
+
+        Text(this.message)
+          .fontSize($r('app.float.page_text_font_size'))
+          .textAlign(TextAlign.Start)
+          .width('100%')
+
+        Button('Run cJSON Smoke Again')
+          .onClick(() => {
+            this.runSmoke();
+          })
+      }
+      .width('100%')
+      .padding(24)
+    }
+    .width('100%')
+    .height('100%')
+  }
+}
