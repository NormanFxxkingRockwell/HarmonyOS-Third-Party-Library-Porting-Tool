+#include "napi/native_api.h"
+
+#include <string>
+
+extern "C" {
+typedef struct cJSON cJSON;
+const char *cJSON_Version(void);
+cJSON *cJSON_Parse(const char *value);
+cJSON *cJSON_GetObjectItemCaseSensitive(const cJSON * const object, const char * const string);
+char *cJSON_PrintUnformatted(const cJSON *item);
+char *cJSON_GetStringValue(const cJSON * const item);
+int cJSON_IsString(const cJSON * const item);
+void cJSON_Delete(cJSON *item);
+void cJSON_free(void *object);
+}
+
+static napi_value RunCjsonSmoke(napi_env env, napi_callback_info info)
+{
+    (void)info;
+
+    const char *input = "{\"library\":\"cJSON\",\"status\":\"ok\",\"items\":[1,2,3]}";
+    cJSON *root = cJSON_Parse(input);
+
+    std::string result;
+    if (root == nullptr) {
+        result = "pass=false;reason=parse_failed";
+    } else {
+        cJSON *library = cJSON_GetObjectItemCaseSensitive(root, "library");
+        char *rendered = cJSON_PrintUnformatted(root);
+        const char *library_value = (cJSON_IsString(library) != 0) ? cJSON_GetStringValue(library) : nullptr;
+        if (library_value == nullptr || rendered == nullptr) {
+            result = "pass=false;reason=lookup_or_print_failed";
+        } else {
+            result = "pass=true;version=";
+            result += cJSON_Version();
+            result += ";library=";
+            result += library_value;
+            result += ";rendered=";
+            result += rendered;
+        }
+        if (rendered != nullptr) {
+            cJSON_free(rendered);
+        }
+        cJSON_Delete(root);
+    }
+
+    napi_value output = nullptr;
+    napi_create_string_utf8(env, result.c_str(), result.size(), &output);
+    return output;
+}
+
+EXTERN_C_START
+static napi_value Init(napi_env env, napi_value exports)
+{
+    napi_property_descriptor desc[] = {
+        { "runCjsonSmoke", nullptr, RunCjsonSmoke, nullptr, nullptr, nullptr, napi_default, nullptr }
+    };
+    napi_define_properties(env, exports, sizeof(desc) / sizeof(desc[0]), desc);
+    return exports;
+}
+EXTERN_C_END
 
